@rendermode InteractiveServer
@inject CrmApiClient Api

<div class="card mt-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Задачи</h5>
        <button class="btn btn-sm btn-outline-primary" @onclick="() => showNewForm = true" disabled="@(showNewForm || isLoading)">
            + Добавить
        </button>
    </div>
    <div class="card-body">
        @if (isLoading && tasks is null)
        {
            <p><em>Загрузка...</em></p>
        }
        else
        {
            @if (showNewForm)
            {
                <div class="mb-3 p-3 border rounded">
                    <div class="mb-2">
                        <input @bind="newTitle" class="form-control" placeholder="Название задачи" disabled="@isLoading" />
                    </div>
                    <div class="mb-2">
                        <textarea @bind="newDescription" class="form-control" rows="2" placeholder="Описание (необязательно)"></textarea>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-6">
                            <label class="form-label small">Срок выполнения</label>
                            <input @bind="newDueDate" class="form-control" type="date" />
                        </div>
                    </div>
                    <div>
                        <button class="btn btn-success btn-sm me-2" @onclick="CreateTask" disabled="@isLoading || string.IsNullOrWhiteSpace(newTitle)">
                            Сохранить
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="CancelNew">Отмена</button>
                    </div>
                </div>
            }

            @if (tasks is not null && tasks.Count == 0 && !showNewForm)
            {
                <p class="text-muted mb-0">Нет задач</p>
            }

            @if (tasks is not null)
            {
                <div class="list-group">
                    @foreach (var task in tasks)
                    {
                        <div class="list-group-item list-group-item-action d-flex align-items-start @(task.IsCompleted ? "list-group-item-success" : "")">
                            <div class="form-check me-3">
                                <input class="form-check-input" type="checkbox" checked="@task.IsCompleted"
                                       @onclick="() => ToggleTask(task.Id)" disabled="@isLoading" />
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between">
                                    <strong class="@(task.IsCompleted ? "text-decoration-line-through text-muted" : "")">@task.Title</strong>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTask(task.Id)" disabled="@isLoading">&times;</button>
                                </div>
                                @if (!string.IsNullOrEmpty(task.Description))
                                {
                                    <p class="mb-1 small text-muted">@task.Description</p>
                                }
                                <div class="small">
                                    @if (task.DueDate.HasValue)
                                    {
                                        var dueClass = task.IsCompleted ? "text-muted" :
                                            (task.DueDate.Value.Date < DateTime.Today ? "text-danger" : "text-muted");
                                        <span class="@dueClass">
                                            Срок: @task.DueDate.Value.ToString("dd.MM.yyyy")
                                        </span>
                                    }
                                    @if (task.CompletedAt.HasValue)
                                    {
                                        <span class="text-success ms-2">
                                            Выполнена: @task.CompletedAt.Value.ToString("dd.MM.yyyy HH:mm")
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-danger mt-2 mb-0">@error</div>
            }
        }
    </div>
</div>

@using AspireCRM.Domain.Tasks

@code {
    [Parameter] public string EntityType { get; set; } = string.Empty;
    [Parameter] public long EntityId { get; set; }

    private List<CrmTask>? tasks;
    private bool isLoading;
    private bool showNewForm;
    private string? error;

    private string newTitle = "";
    private string? newDescription;
    private DateTime? newDueDate;

    protected override async Task OnInitializedAsync() => await LoadTasks();

    private async Task LoadTasks()
    {
        isLoading = true;
        error = null;
        try
        {
            tasks = await Api.GetTasksAsync(EntityType, EntityId);
        }
        catch (Exception ex)
        {
            error = $"Ошибка загрузки: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void CancelNew()
    {
        showNewForm = false;
        newTitle = "";
        newDescription = null;
        newDueDate = null;
    }

    private async Task CreateTask()
    {
        if (string.IsNullOrWhiteSpace(newTitle)) return;
        isLoading = true;
        error = null;
        try
        {
            var task = new CrmTask
            {
                Title = newTitle.Trim(),
                Description = newDescription,
                DueDate = newDueDate,
                EntityType = EntityType,
                EntityId = EntityId,
                IsCompleted = false
            };
            await Api.CreateTaskAsync(task);
            CancelNew();
            await LoadTasks();
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ToggleTask(long id)
    {
        isLoading = true;
        error = null;
        try
        {
            await Api.ToggleTaskAsync(id);
            await LoadTasks();
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteTask(long id)
    {
        isLoading = true;
        error = null;
        try
        {
            await Api.DeleteTaskAsync(id);
            await LoadTasks();
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}