@page "/login"
@rendermode InteractiveServer
@using System.Net.Http.Json
@inject HttpClient Http
@inject AuthTokenStore TokenStore
@inject JwtAuthStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Вход в систему</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h3>Вход в AspireCRM</h3>
            </div>
            <div class="card-body">
                <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input @bind="Email" @bind:event="oninput" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Пароль</label>
                            <input @bind="Password" @bind:event="oninput" type="password" class="form-control" />
                        </div>

                        <button type="button" class="btn btn-primary w-100" disabled="@IsLoading" @onclick="HandleLogin">
                            @(IsLoading ? "Вход..." : "Войти")
                        </button>

                @if (!string.IsNullOrEmpty(Error))
                {
                    <div class="alert alert-danger mt-3">@Error</div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string Email { get; set; } = "";
    private string Password { get; set; } = "";
    private bool IsLoading { get; set; }
    private string? Error { get; set; }

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Password))
        {
            Error = "Заполните email и пароль";
            return;
        }

        IsLoading = true;
        Error = null;
        try
        {
            var response = await Http.PostAsJsonAsync("https+http://apiservice/api/auth/login", new { Email, Password });
            if (!response.IsSuccessStatusCode)
            {
                Error = "Неверный email или пароль";
                return;
            }
            var result = await response.Content.ReadFromJsonAsync<LoginResult>();
            if (result is not null)
            {
                await TokenStore.SetTokenAsync(result.Token);
                AuthStateProvider.NotifyAuthStateChanged();
                Navigation.NavigateTo("/");
            }
        }
        catch (Exception ex)
        {
            Error = $"Ошибка подключения: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private record LoginResult(string Token, long UserId, long TenantId);
}