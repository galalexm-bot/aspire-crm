@page "/leads"
@rendermode InteractiveServer
@inject CrmApiClient Api
@inject NavigationManager Nav

<PageTitle>Лиды</PageTitle>

<h1>Лиды</h1>

<p>
    <a href="/leads/new" class="btn btn-primary">+ Новый лид</a>
    @if (selectedIds.Count > 0)
    {
        <button class="btn btn-info ms-2" @onclick="ActivateSelected" disabled="@isLoading">
            Активировать (@selectedIds.Count)
        </button>
        <button class="btn btn-secondary ms-2" @onclick="ClearSelection">Снять выделение</button>
    }
</p>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}
@if (!string.IsNullOrEmpty(success))
{
    <div class="alert alert-success">@success</div>
}

@if (leads is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>
                    <input type="checkbox" @bind="selectAll" @bind:after="ToggleSelectAll" />
                </th>
                <th>ID</th>
                <th>Название</th>
                <th>Статус</th>
                <th>Дата создания</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var lead in leads)
            {
                <tr>
                    <td>
                        <input type="checkbox" checked="@selectedIds.Contains(lead.Id)"
                               @onchange="() => ToggleSelection(lead.Id)" />
                    </td>
                    <td>@lead.Id</td>
                    <td>
                        @lead.Name
                        @if (lead.Status == LeadStatus.Dublicate)
                        {
                            <span class="badge bg-secondary ms-1">дубль</span>
                        }
                    </td>
                    <td>
                        <span class="badge @StatusBadgeClass(lead.Status)">@StatusDisplay(lead.Status)</span>
                    </td>
                    <td>@lead.CreatedAt.ToShortDateString()</td>
                    <td>
                        <a href="/leads/@lead.Id" class="btn btn-sm btn-outline-primary">Открыть</a>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(lead.Id)">Удалить</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Lead>? leads;
    private HashSet<long> selectedIds = [];
    private bool selectAll;
    private bool isLoading;
    private string? error;
    private string? success;

    protected override async Task OnInitializedAsync()
    {
        leads = await Api.GetLeadsAsync();
    }

    private async Task Delete(long id)
    {
        await Api.DeleteLeadAsync(id);
        leads = await Api.GetLeadsAsync();
        selectedIds.Remove(id);
    }

    private void ToggleSelection(long id)
    {
        if (!selectedIds.Remove(id))
            selectedIds.Add(id);
        selectAll = selectedIds.Count == leads?.Count;
    }

    private void ToggleSelectAll()
    {
        if (leads is null) return;
        if (selectAll)
        {
            selectedIds = [.. leads.Select(l => l.Id)];
        }
        else
        {
            selectedIds.Clear();
        }
    }

    private void ClearSelection()
    {
        selectedIds.Clear();
        selectAll = false;
    }

    private async Task ActivateSelected()
    {
        isLoading = true;
        error = null;
        success = null;
        try
        {
            await Api.ActivateLeadsAsync([.. selectedIds]);
            success = $"Активировано лидов: {selectedIds.Count}";
            ClearSelection();
            leads = await Api.GetLeadsAsync();
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string StatusDisplay(LeadStatus status) => status switch
    {
        LeadStatus.New => "Новый",
        LeadStatus.InHand => "В работе",
        LeadStatus.Qualified => "Квалифицирован",
        LeadStatus.Unqualified => "Неквалифицирован",
        LeadStatus.Dublicate => "Дубликат",
        LeadStatus.ConversationNotStart => "Разговор не состоялся",
        _ => status.ToString()
    };

    private string StatusBadgeClass(LeadStatus status) => status switch
    {
        LeadStatus.New => "bg-primary",
        LeadStatus.InHand => "bg-warning text-dark",
        LeadStatus.Qualified => "bg-success",
        LeadStatus.Unqualified => "bg-danger",
        LeadStatus.Dublicate => "bg-secondary",
        LeadStatus.ConversationNotStart => "bg-dark",
        _ => "bg-light"
    };
}