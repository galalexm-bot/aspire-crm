@page "/leads/{Id:long}"
@rendermode InteractiveServer
@inject CrmApiClient Api
@inject NavigationManager Nav

<PageTitle>Лид @(lead?.Name ?? "")</PageTitle>

<h1>Лид</h1>

@if (lead is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Название</label>
                <input @bind="lead.Name" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">Статус</label>
                <select @bind="lead.Status" class="form-select">
                    <option value="@LeadStatus.New">Новый</option>
                    <option value="@LeadStatus.InHand">В работе</option>
                    <option value="@LeadStatus.Qualified">Квалифицирован</option>
                    <option value="@LeadStatus.Unqualified">Неквалифицирован</option>
                    <option value="@LeadStatus.Dublicate">Дубликат</option>
                    <option value="@LeadStatus.ConversationNotStart">Разговор не начат</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Описание</label>
                <textarea @bind="lead.Description" class="form-control" rows="3"></textarea>
            </div>
            <button class="btn btn-primary" @onclick="Save">Сохранить</button>
            <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/leads")'>Назад</button>
        </div>
    </div>
}

@code {
    [Parameter] public long Id { get; set; }
    private Lead? lead;

    protected override async Task OnInitializedAsync()
    {
        lead = await Api.GetLeadAsync(Id);
    }

    private async Task Save()
    {
        if (lead is not null)
        {
            await Api.UpdateLeadAsync(Id, lead);
            Nav.NavigateTo("/leads");
        }
    }
}