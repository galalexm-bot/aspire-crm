@page "/leads/{Id:long}"
@rendermode InteractiveServer
@inject CrmApiClient Api
@inject NavigationManager Nav

<PageTitle>Лид @(lead?.Name ?? "")</PageTitle>

<h1>Лид</h1>

@if (lead is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Название</label>
                <input @bind="lead.Name" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">Статус</label>
                <span class="badge @StatusBadgeClass(lead?.Status) fs-6">@StatusDisplay(lead?.Status)</span>
            </div>
            <div class="mb-3">
                <label class="form-label">Описание</label>
                <textarea @bind="lead.Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <button class="btn btn-primary me-2" @onclick="Save">Сохранить</button>
                <button class="btn btn-secondary me-2" @onclick='() => Nav.NavigateTo("/leads")'>Назад</button>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5>Действия</h5>
        </div>
        <div class="card-body">
            @if (lead.Status == LeadStatus.New || lead.Status == LeadStatus.ConversationNotStart)
            {
                <button class="btn btn-success me-2" @onclick="BeginWork" disabled="@isLoading">
                    Взять в работу
                </button>
                <button class="btn btn-danger me-2" @onclick="() => showFailModal = true" disabled="@isLoading">
                    Отказать
                </button>
            }
            @if (lead.Status == LeadStatus.InHand)
            {
                <button class="btn btn-success me-2" @onclick="QualifyLead" disabled="@isLoading">
                    Квалифицировать
                </button>
                <button class="btn btn-danger me-2" @onclick="() => showFailModal = true" disabled="@isLoading">
                    Отказать
                </button>
                <button class="btn btn-warning me-2" @onclick="ConversationNotStart" disabled="@isLoading">
                    Разговор не состоялся
                </button>
            }
            @if (lead.Status is LeadStatus.Qualified or LeadStatus.InHand)
            {
                <a href="/leads/@Id/convert" class="btn btn-primary me-2">
                    Конвертировать
                </a>
            }
            @if (lead.Status == LeadStatus.Unqualified || lead.Status == LeadStatus.Dublicate)
            {
                <button class="btn btn-info me-2" @onclick="ActivateLead" disabled="@isLoading">
                    Активировать
                </button>
            }
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header">
            <h5>Дубликаты</h5>
        </div>
        <div class="card-body">
            @if (lead.Status == LeadStatus.Dublicate)
            {
                <p>
                    <strong>Дубликат лида:</strong> @lead.DublicateLead
                </p>
                @if (!string.IsNullOrEmpty(lead.DublicateComment))
                {
                    <p><strong>Комментарий:</strong> @lead.DublicateComment</p>
                }
                <button class="btn btn-outline-secondary" @onclick="UnmarkDuplicate" disabled="@isLoading">
                    Снять дубликат
                </button>
            }
            else
            {
                <button class="btn btn-outline-info" @onclick="LoadDuplicates" disabled="@isLoading">
                    Проверить дубликаты
                </button>
            }
        </div>
    </div>

    @if (showFailModal)
    {
        <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Отказ по лиду</h5>
                        <button type="button" class="btn-close" @onclick="() => showFailModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Комментарий</label>
                            <textarea @bind="failComment" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => showFailModal = false">Отмена</button>
                        <button class="btn btn-danger" @onclick="FailLead" disabled="@isLoading">
                            Подтвердить отказ
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger mt-3">@error</div>
    }
    @if (!string.IsNullOrEmpty(success))
    {
        <div class="alert alert-success mt-3">@success</div>
    }

    @if (showDuplicateModal)
    {
        <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Поиск дубликатов</h5>
                        <button type="button" class="btn-close" @onclick="() => showDuplicateModal = false"></button>
                    </div>
                    <div class="modal-body">
                        @if (duplicateCandidates is null)
                        {
                            <p><em>Поиск...</em></p>
                        }
                        else if (duplicateCandidates.Count == 0)
                        {
                            <p>Дубликаты не найдены</p>
                        }
                        else
                        {
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Название</th>
                                        <th>Статус</th>
                                        <th>Совпадение</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var c in duplicateCandidates)
                                    {
                                        <tr>
                                            <td>@c.Id</td>
                                            <td>@c.Name</td>
                                            <td>
                                                <span class="badge @StatusBadgeClass(c.Status)">@StatusDisplay(c.Status)</span>
                                            </td>
                                            <td>@(c.Similarity.ToString("P0"))</td>
                                            <td>
                                                <button class="btn btn-sm btn-warning" @onclick="() => MarkAsDuplicate(c.Id)" disabled="@isLoading">
                                                    Это дубликат
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => showDuplicateModal = false">Закрыть</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="mt-3">
        <AttachmentList EntityType="Lead" EntityId="Id" />
    </div>

    <div class="mt-3">
        <TaskList EntityType="Lead" EntityId="Id" />
    </div>
}

@using AspireCRM.Web.Models

@code {
    [Parameter] public long Id { get; set; }
    private Lead? lead;
    private bool isLoading;
    private string? error;
    private string? success;
    private bool showFailModal;
    private string? failComment;
    private bool showDuplicateModal;
    private List<DuplicateCandidate>? duplicateCandidates;

    private string StatusDisplay(LeadStatus? status) => status switch
    {
        LeadStatus.New => "Новый",
        LeadStatus.InHand => "В работе",
        LeadStatus.Qualified => "Квалифицирован",
        LeadStatus.Unqualified => "Неквалифицирован",
        LeadStatus.Dublicate => "Дубликат",
        LeadStatus.ConversationNotStart => "Разговор не состоялся",
        _ => status?.ToString() ?? ""
    };

    private string StatusBadgeClass(LeadStatus? status) => status switch
    {
        LeadStatus.New => "bg-primary",
        LeadStatus.InHand => "bg-warning text-dark",
        LeadStatus.Qualified => "bg-success",
        LeadStatus.Unqualified => "bg-danger",
        LeadStatus.Dublicate => "bg-secondary",
        LeadStatus.ConversationNotStart => "bg-dark",
        _ => "bg-light"
    };

    protected override async Task OnInitializedAsync()
    {
        lead = await Api.GetLeadAsync(Id);
    }

    private async Task Save()
    {
        isLoading = true;
        error = null;
        success = null;
        try
        {
            if (lead is not null)
            {
                await Api.UpdateLeadAsync(Id, lead);
                success = "Лид сохранен";
            }
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task BeginWork()
    {
        isLoading = true;
        error = null;
        success = null;
        try
        {
            await Api.BeginLeadAsync(Id);
            lead = await Api.GetLeadAsync(Id);
            success = "Статус изменен на \"В работе\"";
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task FailLead()
    {
        showFailModal = false;
        isLoading = true;
        error = null;
        success = null;
        try
        {
            await Api.FailLeadAsync(Id, failComment);
            lead = await Api.GetLeadAsync(Id);
            success = "Статус изменен на \"Неквалифицирован\"";
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ConversationNotStart()
    {
        isLoading = true;
        error = null;
        success = null;
        try
        {
            await Api.ConversationNotStartAsync(Id);
            lead = await Api.GetLeadAsync(Id);
            success = "Статус изменен на \"Разговор не состоялся\"";
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task QualifyLead()
    {
        isLoading = true;
        error = null;
        success = null;
        try
        {
            if (lead is null) return;
            lead.Status = LeadStatus.Qualified;
            await Api.UpdateLeadAsync(Id, lead);
            lead = await Api.GetLeadAsync(Id);
            success = "Статус изменен на \"Квалифицирован\"";
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ActivateLead()
    {
        isLoading = true;
        error = null;
        success = null;
        try
        {
            await Api.ActivateLeadsAsync([Id]);
            lead = await Api.GetLeadAsync(Id);
            success = "Лид активирован";
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadDuplicates()
    {
        isLoading = true;
        error = null;
        duplicateCandidates = null;
        showDuplicateModal = true;
        try
        {
            duplicateCandidates = await Api.GetDuplicatesAsync(Id);
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task MarkAsDuplicate(long targetLeadId)
    {
        isLoading = true;
        error = null;
        success = null;
        try
        {
            await Api.MarkDuplicateAsync(Id, targetLeadId);
            lead = await Api.GetLeadAsync(Id);
            showDuplicateModal = false;
            success = "Лид помечен как дубликат";
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UnmarkDuplicate()
    {
        isLoading = true;
        error = null;
        success = null;
        try
        {
            await Api.UnmarkDuplicateAsync(Id);
            lead = await Api.GetLeadAsync(Id);
            success = "Пометка о дубликате снята";
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}