@using AspireCRM.Web.Models
@inject CrmApiClient Api

<div class="card mb-4">
    <div class="card-header">
        <h5 class="card-title mb-0">Сводка по сделкам</h5>
    </div>
    <div class="card-body">
        @if (summary is null)
        {
            <p><em>Загрузка...</em></p>
        }
        else
        {
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="border rounded p-3 text-center bg-light">
                        <div class="fs-3 fw-bold text-primary">@summary.TotalActive</div>
                        <div class="text-muted">Активные</div>
                        <div class="small text-secondary">@summary.ActiveSalesVolume.ToString("N0") ₽</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="border rounded p-3 text-center bg-light">
                        <div class="fs-3 fw-bold text-warning">@summary.TotalPostponed</div>
                        <div class="text-muted">Отложенные</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="border rounded p-3 text-center bg-light">
                        <div class="fs-3 fw-bold text-success">@summary.TotalPositiveClosed</div>
                        <div class="text-muted">Успешно закрыты</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="border rounded p-3 text-center bg-light">
                        <div class="fs-3 fw-bold text-danger">@summary.TotalNegativeClosed</div>
                        <div class="text-muted">Провалены</div>
                    </div>
                </div>
                @if (summary.OverdueCount > 0)
                {
                    <div class="col-md-3">
                        <div class="border rounded p-3 text-center border-danger">
                            <div class="fs-3 fw-bold text-danger">@summary.OverdueCount</div>
                            <div class="text-muted">Просроченные</div>
                        </div>
                    </div>
                }
            </div>
            <hr />
            <div class="row">
                <div class="col">
                    <div class="text-muted">Общий объём продаж: <strong>@summary.TotalSalesVolume.ToString("N0") ₽</strong></div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private SaleSummary? summary;

    protected override async Task OnInitializedAsync()
    {
        summary = await Api.GetSaleSummaryAsync();
    }
}