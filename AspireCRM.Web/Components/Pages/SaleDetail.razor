@page "/sales/{Id:long}"
@rendermode InteractiveServer
@inject CrmApiClient Api
@inject NavigationManager Nav

<PageTitle>Сделка @(sale?.Name ?? "")</PageTitle>

<h1>Сделка</h1>

@if (sale is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger">@error</div>
    }
    @if (!string.IsNullOrEmpty(success))
    {
        <div class="alert alert-success">@success</div>
    }

    <div class="card mb-3">
        <div class="card-header"><h5>Основная информация</h5></div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Название</label>
                    <input @bind="sale.Name" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Контрагент</label>
                    <select @bind="sale.ContractorId" class="form-select">
                        <option value="0">-- Выберите --</option>
                        @foreach (var c in contractors)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Статус</label>
                    <span class="badge @StatusBadgeClass(sale.SaleStatus) fs-6">@StatusDisplay(sale.SaleStatus)</span>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Приоритет</label>
                    <select @bind="sale.Priority" class="form-select">
                        <option value="@SalePriority.High">Высокий</option>
                        <option value="@SalePriority.Medium">Средний</option>
                        <option value="@SalePriority.Low">Низкий</option>
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Дата старта</label>
                    <input @bind="sale.StartDate" class="form-control" type="date" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Воронка</label>
                    <select @bind="sale.SaleFunnelId" class="form-select">
                        <option value="">-- Выберите --</option>
                        @foreach (var f in funnels)
                        {
                            <option value="@f.Id">@f.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Этап</label>
                    <select @bind="sale.SaleStageId" class="form-select">
                        <option value="">-- Выберите --</option>
                        @foreach (var s in stages)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Тип сделки</label>
                    <select @bind="sale.SaleTypeId" class="form-select">
                        <option value="0">-- Выберите --</option>
                        @foreach (var t in types)
                        {
                            <option value="@t.Id">@t.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Валюта</label>
                    <select @bind="sale.CurrencyId" class="form-select">
                        <option value="">-- Выберите --</option>
                        @foreach (var c in currencies)
                        {
                            <option value="@c.Id">@c.Name (@c.Code)</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Маркетинговый эффект</label>
                    <input @bind="sale.MarketingEffect" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Объем продаж</label>
                    <input @bind="sale.SalesVolume" class="form-control" type="number" step="0.01" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Описание</label>
                <textarea @bind="sale.Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <button class="btn btn-primary me-2" @onclick="Save" disabled="@isLoading">Сохранить</button>
                <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/sales")'>Назад</button>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><h5>Смена этапа и статуса</h5></div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Текущий статус</label>
                    <span class="badge @StatusBadgeClass(sale.SaleStatus) fs-6 d-block text-start p-2">@StatusDisplay(sale.SaleStatus)</span>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Текущий этап</label>
                    <span class="badge bg-info text-dark fs-6 d-block text-start p-2">
                        @(stages.FirstOrDefault(s => s.Id == sale.SaleStageId)?.Name ?? "Не выбран")
                    </span>
                </div>
            </div>

            <hr />
            <h6>Сменить этап</h6>
            <div class="row align-items-end">
                <div class="col-md-4 mb-2">
                    <select @bind="selectedStageId" class="form-select">
                        <option value="">-- Выберите этап --</option>
                        @foreach (var s in stages)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 mb-2">
                    <input @bind="stageComment" class="form-control" placeholder="Комментарий (необязательно)" />
                </div>
                <div class="col-md-2 mb-2">
                    <button class="btn btn-warning" @onclick="ChangeStage" disabled="@isLoading">Сменить этап</button>
                </div>
            </div>

            <hr />
            <h6>Сменить статус</h6>
            <div class="row align-items-end">
                <div class="col-md-4 mb-2">
                    <input @bind="statusComment" class="form-control" placeholder="Комментарий (необязательно)" />
                </div>
                <div class="col-md-6 mb-2">
                    @if (sale.SaleStatus != SaleStatus.Postponed)
                    {
                        <button class="btn btn-warning me-2" @onclick="() => ChangeStatus(SaleStatus.Postponed)" disabled="@isLoading">Отложить</button>
                    }
                    @if (sale.SaleStatus != SaleStatus.PositiveClosed)
                    {
                        <button class="btn btn-success me-2" @onclick="() => ChangeStatus(SaleStatus.PositiveClosed)" disabled="@isLoading">Закрыть успешно</button>
                    }
                    @if (sale.SaleStatus != SaleStatus.NegativeClosed)
                    {
                        <button class="btn btn-danger" @onclick="() => ChangeStatus(SaleStatus.NegativeClosed)" disabled="@isLoading">Закрыть неуспешно</button>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><h5>Товары</h5></div>
        <div class="card-body">
            @if (saleProducts.Count == 0)
            {
                <p class="text-muted">Нет товаров</p>
            }
            else
            {
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Товар</th>
                            <th>Кол-во</th>
                            <th>Цена</th>
                            <th>Скидка</th>
                            <th>Сумма</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sp in saleProducts)
                        {
                            <tr>
                                <td>@sp.Product?.Name</td>
                                <td>@sp.Quantity</td>
                                <td>@sp.Price.ToString("F2")</td>
                                <td>@(sp.Discount?.ToString("F2") ?? "-")</td>
                                <td>@((sp.Quantity * sp.Price * (1 - (sp.Discount ?? 0) / 100)).ToString("F2"))</td>
                                <td>
                                    <button class="btn btn-danger btn-sm" @onclick="() => RemoveProduct(sp.Id)" disabled="@isLoading">Удалить</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <hr />
            <h6>Добавить товар</h6>
            <div class="row">
                <div class="col-md-3 mb-2">
                    <select @bind="newProduct.ProductId" class="form-select form-select-sm">
                        <option value="0">-- Выберите товар --</option>
                        @foreach (var p in products)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 mb-2">
                    <input @bind="newProduct.Quantity" class="form-control form-control-sm" placeholder="Кол-во" type="number" step="any" />
                </div>
                <div class="col-md-2 mb-2">
                    <input @bind="newProduct.Price" class="form-control form-control-sm" placeholder="Цена" type="number" step="0.01" />
                </div>
                <div class="col-md-2 mb-2">
                    <input @bind="newProduct.Discount" class="form-control form-control-sm" placeholder="Скидка %" type="number" step="0.01" />
                </div>
                <div class="col-md-1 mb-2">
                    <button class="btn btn-success btn-sm" @onclick="AddProduct" disabled="@isLoading">+</button>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <TaskList EntityType="Sale" EntityId="Id" />
    </div>

    <div class="mt-3">
        <CommentList EntityType="Sale" EntityId="Id" />
    </div>

    <div class="mt-3">
        <AuditHistory EntityType="Sale" EntityId="Id" />
    </div>
}

@code {
    [Parameter] public long Id { get; set; }

    private Sale? sale;
    private bool isLoading;
    private string? error;
    private string? success;

    private List<Contractor> contractors = [];
    private List<SaleFunnel> funnels = [];
    private List<SaleStage> stages = [];
    private List<SaleType> types = [];
    private List<Currency> currencies = [];

    private List<SaleProduct> saleProducts = [];
    private List<Product> products = [];
    private SaleProduct newProduct = new() { Quantity = 1, ProductId = 0 };

    private long? selectedStageId;
    private string? stageComment;
    private string? statusComment;

    private string StatusDisplay(SaleStatus status) => status switch
    {
        SaleStatus.Active => "Активна",
        SaleStatus.Postponed => "Отложена",
        SaleStatus.PositiveClosed => "Закрыта успешно",
        SaleStatus.NegativeClosed => "Закрыта неуспешно",
        _ => status.ToString()
    };

    private string StatusBadgeClass(SaleStatus status) => status switch
    {
        SaleStatus.Active => "bg-success",
        SaleStatus.Postponed => "bg-warning text-dark",
        SaleStatus.PositiveClosed => "bg-primary",
        SaleStatus.NegativeClosed => "bg-danger",
        _ => "bg-light"
    };

    protected override async Task OnInitializedAsync()
    {
        var loadTask = LoadSale();
        var lookupTask = LoadLookups();
        var productsTask = LoadProducts();
        await Task.WhenAll(loadTask, lookupTask, productsTask);
        if (sale is not null)
            await LoadSaleProducts();
    }

    private async Task LoadSale()
    {
        try
        {
            sale = await Api.GetSaleAsync(Id);
        }
        catch (Exception ex)
        {
            error = $"Ошибка загрузки: {ex.Message}";
        }
    }

    private async Task LoadLookups()
    {
        var tasks = new Task[]
        {
            Task.Run(async () => { try { contractors = await Api.GetContractorsListAsync(); } catch { } }),
            Task.Run(async () => { try { funnels = await Api.GetLookupAsync<SaleFunnel>("sale-funnels"); } catch { } }),
            Task.Run(async () => { try { stages = await Api.GetLookupAsync<SaleStage>("sale-stages"); } catch { } }),
            Task.Run(async () => { try { types = await Api.GetLookupAsync<SaleType>("sale-types"); } catch { } }),
            Task.Run(async () => { try { currencies = await Api.GetLookupAsync<Currency>("currencies"); } catch { } })
        };
        await Task.WhenAll(tasks);
    }

    private async Task LoadSaleProducts()
    {
        try
        {
            saleProducts = await Api.GetSaleProductsAsync(Id);
        }
        catch { }
    }

    private async Task LoadProducts()
    {
        try
        {
            products = await Api.GetProductsAsync();
        }
        catch { }
    }

    private async Task AddProduct()
    {
        if (newProduct.ProductId <= 0)
        {
            error = "Выберите товар";
            return;
        }
        if (newProduct.Quantity <= 0)
        {
            error = "Количество должно быть больше 0";
            return;
        }
        if (newProduct.Price <= 0)
        {
            error = "Цена должна быть больше 0";
            return;
        }

        isLoading = true;
        error = null;
        try
        {
            newProduct.SaleId = Id;
            await Api.CreateSaleProductAsync(Id, newProduct);
            await LoadSaleProducts();
            newProduct = new SaleProduct { Quantity = 1, ProductId = 0 };
            success = "Товар добавлен";
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RemoveProduct(long productId)
    {
        isLoading = true;
        error = null;
        try
        {
            await Api.DeleteSaleProductAsync(Id, productId);
            await LoadSaleProducts();
            success = "Товар удалён";
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ChangeStage()
    {
        if (sale is null) return;
        if (!selectedStageId.HasValue || selectedStageId.Value <= 0)
        {
            error = "Выберите этап";
            return;
        }
        if (selectedStageId.Value == sale.SaleStageId)
        {
            error = "Сделка уже на этом этапе";
            return;
        }

        isLoading = true;
        error = null;
        success = null;
        try
        {
            sale = await Api.ChangeSaleStageAsync(Id, selectedStageId.Value, stageComment);
            stageComment = null;
            success = "Этап изменён";
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ChangeStatus(SaleStatus newStatus)
    {
        if (sale is null) return;
        if (sale.SaleStatus == newStatus)
        {
            error = $"Статус уже \"{StatusDisplay(newStatus)}\"";
            return;
        }

        isLoading = true;
        error = null;
        success = null;
        try
        {
            sale = await Api.ChangeSaleStatusAsync(Id, newStatus.ToString(), statusComment);
            statusComment = null;
            success = "Статус изменён";
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Save()
    {
        if (sale is null) return;

        if (string.IsNullOrWhiteSpace(sale.Name))
        {
            error = "Название обязательно";
            return;
        }
        if (sale.ContractorId <= 0)
        {
            error = "Выберите контрагента";
            return;
        }
        if (sale.SaleTypeId <= 0)
        {
            error = "Выберите тип сделки";
            return;
        }

        isLoading = true;
        error = null;
        success = null;
        try
        {
            await Api.UpdateSaleAsync(Id, sale);
            success = "Сделка сохранена";
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}