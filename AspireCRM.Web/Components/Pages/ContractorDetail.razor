@page "/contractors/{Id:long}"
@using AspireCRM.Web.Models
@rendermode InteractiveServer
@inject CrmApiClient Api
@inject NavigationManager Nav

<PageTitle>Контрагент @(contractor?.Name ?? "")</PageTitle>

<h1>Контрагент</h1>

@if (contractor is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger">@error</div>
    }
    @if (!string.IsNullOrEmpty(success))
    {
        <div class="alert alert-success">@success</div>
    }

    <div class="card mb-3">
        <div class="card-header"><h5>Основная информация</h5></div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Название</label>
                    <input @bind="name" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Тип контрагента</label>
                    <select class="form-select" @bind="contractorTypeId">
                        <option value="">-- Выберите --</option>
                        @foreach (var t in contractorTypes)
                        {
                            <option value="@t.Id">@t.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Описание</label>
                <textarea @bind="description" class="form-control" rows="2"></textarea>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Сайт</label>
                    <input @bind="site" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Факс</label>
                    <input @bind="fax" class="form-control" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">ИНН</label>
                    <input @bind="inn" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Годовой доход</label>
                    <input @bind="annualIncome" class="form-control" type="number" step="0.01" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">День компании</label>
                    <input @bind="companyDay" class="form-control" type="date" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Регион</label>
                    <select class="form-select" @bind="regionId">
                        <option value="">-- Выберите --</option>
                        @foreach (var r in regions)
                        {
                            <option value="@r.Id">@r.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Отрасль</label>
                    <select class="form-select" @bind="industryId">
                        <option value="">-- Выберите --</option>
                        @foreach (var ind in industries)
                        {
                            <option value="@ind.Id">@ind.Name</option>
                        }
                    </select>
                </div>
            </div>

            @if (isLegal)
            {
                <div class="card mb-3">
                    <div class="card-header"><h5>Данные юридического лица</h5></div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Организационно-правовая форма</label>
                                <select class="form-select" @bind="legalFormId">
                                    <option value="">-- Выберите --</option>
                                    @foreach (var lf in legalForms)
                                    {
                                        <option value="@lf.Id">@lf.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Численность сотрудников</label>
                                <input @bind="staff" class="form-control" type="number" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">ОГРН</label>
                                <input @bind="ogrn" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">КПП</label>
                                <input @bind="kpp" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (isIndividual)
            {
                <div class="card mb-3">
                    <div class="card-header"><h5>Данные физического лица / ИП</h5></div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Фамилия</label>
                                <input @bind="firstName" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Имя</label>
                                <input @bind="secondName" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Отчество</label>
                                <input @bind="middleName" class="form-control" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Тип документа</label>
                                <select class="form-select" @bind="documentTypeId">
                                    <option value="">-- Выберите --</option>
                                    @foreach (var dt in documentTypes)
                                    {
                                        <option value="@dt.Id">@dt.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Серия</label>
                                <input @bind="documentSeries" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Номер</label>
                                <input @bind="documentNumber" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Кем выдан</label>
                            <input @bind="documentIssued" class="form-control" />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Дата выдачи</label>
                                <input @bind="documentIssueDate" class="form-control" type="date" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Дата окончания</label>
                                <input @bind="documentEndDate" class="form-control" type="date" />
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="mb-3">
                <button class="btn btn-primary me-2" @onclick="Save" disabled="@isLoading">Сохранить</button>
                <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/contractors")'>Назад</button>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-header"><h5 class="d-inline">Юридический адрес</h5>
                    <button class="btn btn-sm btn-outline-success float-end" @onclick="SaveLegalAddress" disabled="@isLoading">Сохранить адрес</button>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <label class="form-label">Страна</label>
                        <input @bind="legalCountry" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Город</label>
                        <input @bind="legalCity" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Улица</label>
                        <input @bind="legalStreet" class="form-control" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Дом</label>
                            <input @bind="legalBuilding" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Квартира</label>
                            <input @bind="legalApartment" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Индекс</label>
                        <input @bind="legalZipCode" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Полный адрес</label>
                        <input @bind="legalFullAddress" class="form-control" />
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-header"><h5 class="d-inline">Фактический адрес</h5>
                    <button class="btn btn-sm btn-outline-success float-end" @onclick="SavePostalAddress" disabled="@isLoading">Сохранить адрес</button>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <label class="form-label">Страна</label>
                        <input @bind="postalCountry" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Город</label>
                        <input @bind="postalCity" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Улица</label>
                        <input @bind="postalStreet" class="form-control" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Дом</label>
                            <input @bind="postalBuilding" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Квартира</label>
                            <input @bind="postalApartment" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Индекс</label>
                        <input @bind="postalZipCode" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Полный адрес</label>
                        <input @bind="postalFullAddress" class="form-control" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-header">
                    <h5 class="d-inline">Email</h5>
                    <button class="btn btn-sm btn-outline-primary float-end" @onclick="() => showNewEmail = true">+ Добавить</button>
                </div>
                <div class="card-body">
                    @if (showNewEmail)
                    {
                        <div class="input-group mb-2">
                            <input @bind="newEmailAddress" class="form-control" placeholder="Email" />
                            <input @bind="newEmailDescription" class="form-control" placeholder="Описание" />
                            <button class="btn btn-success" @onclick="AddEmail" disabled="@isLoading">Добавить</button>
                            <button class="btn btn-outline-secondary" @onclick="CancelNewEmail">Отмена</button>
                        </div>
                    }
                    @if (emails.Count == 0)
                    {
                        <p class="text-muted mb-0">Нет email</p>
                    }
                    @foreach (var email in emails)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span><strong>@email.EmailAddress</strong> @(string.IsNullOrEmpty(email.Description) ? "" : $"({email.Description})")</span>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveEmail(email.Id)" disabled="@isLoading">&times;</button>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-header">
                    <h5 class="d-inline">Телефоны</h5>
                    <button class="btn btn-sm btn-outline-primary float-end" @onclick="() => showNewPhone = true">+ Добавить</button>
                </div>
                <div class="card-body">
                    @if (showNewPhone)
                    {
                        <div class="input-group mb-2">
                            <input @bind="newPhoneNumber" class="form-control" placeholder="Телефон" />
                            <input @bind="newPhoneDescription" class="form-control" placeholder="Описание" />
                            <button class="btn btn-success" @onclick="AddPhone" disabled="@isLoading">Добавить</button>
                            <button class="btn btn-outline-secondary" @onclick="CancelNewPhone">Отмена</button>
                        </div>
                    }
                    @if (phones.Count == 0)
                    {
                        <p class="text-muted mb-0">Нет телефонов</p>
                    }
                    @foreach (var phone in phones)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span><strong>@phone.PhoneNumber</strong> @(string.IsNullOrEmpty(phone.Description) ? "" : $"({phone.Description})")</span>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemovePhone(phone.Id)" disabled="@isLoading">&times;</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-header">
                    <h5 class="d-inline">Банковские счета</h5>
                    <button class="btn btn-sm btn-outline-primary float-end" @onclick="OpenNewBankAccount">+ Добавить</button>
                </div>
                <div class="card-body">
                    @if (showNewBankAccount)
                    {
                        <div class="mb-2">
                            <input @bind="newBankAccount.Number" class="form-control mb-1" placeholder="Номер счета" />
                            <input @bind="newBankAccount.BIK" class="form-control mb-1" placeholder="БИК" />
                            <input @bind="newBankAccount.BankName" class="form-control mb-1" placeholder="Название банка" />
                            <input @bind="newBankAccount.CorrespondentAccount" class="form-control mb-1" placeholder="Корр. счет" />
                            <input @bind="newBankAccount.Description" class="form-control mb-1" placeholder="Описание" />
                            <button class="btn btn-success btn-sm me-1" @onclick="AddBankAccount" disabled="@isLoading">Добавить</button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelNewBankAccount">Отмена</button>
                        </div>
                    }
                    @if (bankAccounts.Count == 0)
                    {
                        <p class="text-muted mb-0">Нет счетов</p>
                    }
                    @foreach (var account in bankAccounts)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span><strong>@account.Number</strong> @(string.IsNullOrEmpty(account.BankName) ? "" : $"- {account.BankName}")</span>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteBankAccount(account.Id)" disabled="@isLoading">&times;</button>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-header">
                    <h5 class="d-inline">Платежные карты</h5>
                    <button class="btn btn-sm btn-outline-primary float-end" @onclick="OpenNewPaymentCard">+ Добавить</button>
                </div>
                <div class="card-body">
                    @if (showNewPaymentCard)
                    {
                        <div class="mb-2">
                            <input @bind="newPaymentCard.Number" class="form-control mb-1" placeholder="Номер карты" />
                            <input @bind="newPaymentCard.CardholderName" class="form-control mb-1" placeholder="Держатель карты" />
                            <input @bind="newPaymentCard.Description" class="form-control mb-1" placeholder="Описание" />
                            <button class="btn btn-success btn-sm me-1" @onclick="AddPaymentCard" disabled="@isLoading">Добавить</button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelNewPaymentCard">Отмена</button>
                        </div>
                    }
                    @if (paymentCards.Count == 0)
                    {
                        <p class="text-muted mb-0">Нет карт</p>
                    }
                    @foreach (var card in paymentCards)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span>
                                <strong>@card.Number</strong>
                                @(string.IsNullOrEmpty(card.CardholderName) ? "" : $"({card.CardholderName})")
                            </span>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePaymentCard(card.Id)" disabled="@isLoading">&times;</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <AttachmentList EntityType="Contractor" EntityId="Id" />
    </div>
}

@code {
    [Parameter] public long Id { get; set; }

    private Contractor? contractor;
    private bool isLoading;
    private string? error;
    private string? success;

    private bool isLegal;
    private bool isIndividual;

    private string name = "";
    private string? description;
    private string? fax;
    private string? site;
    private string? inn;
    private double? annualIncome;
    private DateTime? companyDay;
    private long? responsibleId;
    private long? regionId;
    private long? industryId;
    private long? contractorTypeId;

    private long? legalFormId;
    private long? staff;
    private string? ogrn;
    private string? kpp;

    private string firstName = "";
    private string? secondName;
    private string? middleName;
    private long? documentTypeId;
    private string? documentSeries;
    private string? documentNumber;
    private string? documentIssued;
    private DateTime? documentIssueDate;
    private DateTime? documentEndDate;

    private string? legalCountry;
    private string? legalCity;
    private string? legalStreet;
    private string? legalBuilding;
    private string? legalApartment;
    private string? legalZipCode;
    private string? legalFullAddress;

    private string? postalCountry;
    private string? postalCity;
    private string? postalStreet;
    private string? postalBuilding;
    private string? postalApartment;
    private string? postalZipCode;
    private string? postalFullAddress;

    private List<Email> emails = [];
    private List<Phone> phones = [];
    private List<BankAccount> bankAccounts = [];
    private List<PaymentCard> paymentCards = [];

    private List<ContractorType> contractorTypes = [];
    private List<ContractorRegion> regions = [];
    private List<ContractorIndustry> industries = [];
    private List<LegalForm> legalForms = [];
    private List<ClientDocumentType> documentTypes = [];

    private bool showNewEmail;
    private string newEmailAddress = "";
    private string? newEmailDescription;

    private bool showNewPhone;
    private string newPhoneNumber = "";
    private string? newPhoneDescription;

    private bool showNewBankAccount;
    private BankAccount newBankAccount = new();

    private bool showNewPaymentCard;
    private PaymentCard newPaymentCard = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        contractor = await Api.GetContractorDetailAsync(Id);
        if (contractor is not null)
        {
            name = contractor.Name;
            description = contractor.Description;
            fax = contractor.Fax;
            site = contractor.Site;
            inn = contractor.INN;
            annualIncome = contractor.AnnualIncome;
            companyDay = contractor.CompanyDay;
            responsibleId = contractor.ResponsibleId;
            regionId = contractor.RegionId;
            industryId = contractor.IndustryId;
            contractorTypeId = contractor.ContractorTypeId;

            isLegal = contractor is ContractorLegal;
            isIndividual = contractor is ContractorIndividual;

            if (contractor is ContractorLegal legal)
            {
                legalFormId = legal.LegalFormId;
                staff = legal.Staff;
                ogrn = legal.OGRN;
                kpp = legal.KPP;
            }
            else if (contractor is ContractorIndividual individual)
            {
                firstName = individual.FirstName;
                secondName = individual.SecondName;
                middleName = individual.MiddleName;
                documentTypeId = individual.DocumentTypeId;
                documentSeries = individual.DocumentSeries;
                documentNumber = individual.DocumentNumber;
                documentIssued = individual.DocumentIssued;
                documentIssueDate = individual.DocumentIssueDate;
                documentEndDate = individual.DocumentEndDate;
            }

            var legalAddr = contractor.LegalAddress;
            legalCountry = legalAddr?.Country;
            legalCity = legalAddr?.City;
            legalStreet = legalAddr?.Street;
            legalBuilding = legalAddr?.Building;
            legalApartment = legalAddr?.Apartment;
            legalZipCode = legalAddr?.ZipCode;
            legalFullAddress = legalAddr?.FullAddress;

            var postalAddr = contractor.PostalAddress;
            postalCountry = postalAddr?.Country;
            postalCity = postalAddr?.City;
            postalStreet = postalAddr?.Street;
            postalBuilding = postalAddr?.Building;
            postalApartment = postalAddr?.Apartment;
            postalZipCode = postalAddr?.ZipCode;
            postalFullAddress = postalAddr?.FullAddress;

            emails = contractor.Emails.ToList();
            phones = contractor.Phones.ToList();
            bankAccounts = contractor.BankAccounts.ToList();
            paymentCards = contractor.PaymentCards.ToList();
        }

        contractorTypes = await Api.GetLookupAsync<ContractorType>("contractor-types");
        regions = await Api.GetLookupAsync<ContractorRegion>("regions");
        industries = await Api.GetLookupAsync<ContractorIndustry>("industries");
        legalForms = await Api.GetLookupAsync<LegalForm>("legal-forms");
        documentTypes = await Api.GetLookupAsync<ClientDocumentType>("document-types");
    }

    private async Task Save()
    {
        isLoading = true;
        error = null;
        success = null;
        try
        {
            var request = new UpdateContractorRequest(
                Name: name,
                Description: description,
                Fax: fax,
                Site: site,
                INN: inn,
                AnnualIncome: annualIncome,
                CompanyDay: companyDay,
                ResponsibleId: responsibleId,
                RegionId: regionId,
                IndustryId: industryId,
                ContractorTypeId: contractorTypeId,
                LegalFormId: legalFormId,
                Staff: staff,
                OGRN: ogrn,
                KPP: kpp,
                FirstName: firstName,
                SecondName: secondName,
                MiddleName: middleName,
                DocumentTypeId: documentTypeId,
                DocumentSeries: documentSeries,
                DocumentNumber: documentNumber,
                DocumentIssued: documentIssued,
                DocumentIssueDate: documentIssueDate,
                DocumentEndDate: documentEndDate,
                LegalAddress: new AddressDto(legalCountry, legalCity, legalStreet, legalBuilding, legalApartment, legalZipCode, legalFullAddress),
                PostalAddress: new AddressDto(postalCountry, postalCity, postalStreet, postalBuilding, postalApartment, postalZipCode, postalFullAddress)
            );

            await Api.UpdateContractorWithDetailsAsync(Id, request);
            success = "Контрагент сохранен";
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveLegalAddress()
    {
        isLoading = true;
        error = null;
        success = null;
        try
        {
            var dto = new AddressDto(legalCountry, legalCity, legalStreet, legalBuilding, legalApartment, legalZipCode, legalFullAddress);
            await Api.UpdateLegalAddressAsync(Id, dto);
            success = "Юридический адрес сохранен";
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SavePostalAddress()
    {
        isLoading = true;
        error = null;
        success = null;
        try
        {
            var dto = new AddressDto(postalCountry, postalCity, postalStreet, postalBuilding, postalApartment, postalZipCode, postalFullAddress);
            await Api.UpdatePostalAddressAsync(Id, dto);
            success = "Фактический адрес сохранен";
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void CancelNewEmail()
    {
        showNewEmail = false;
        newEmailAddress = "";
        newEmailDescription = null;
    }

    private void CancelNewPhone()
    {
        showNewPhone = false;
        newPhoneNumber = "";
        newPhoneDescription = null;
    }

    private async Task AddEmail()
    {
        if (string.IsNullOrWhiteSpace(newEmailAddress)) return;
        isLoading = true;
        error = null;
        try
        {
            var email = await Api.AddContractorEmailAsync(Id, newEmailAddress.Trim(), newEmailDescription);
            emails.Add(email);
            newEmailAddress = "";
            newEmailDescription = null;
            showNewEmail = false;
        }
        catch (Exception ex)
        {
