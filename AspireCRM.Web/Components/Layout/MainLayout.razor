@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="search-box">
                <input type="text" @bind="searchQuery" @bind:event="oninput"
                       @onkeydown="HandleKeyDown" class="form-control form-control-sm"
                       placeholder="Поиск..." />
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private string searchQuery = "";

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(searchQuery))
        {
            var q = Uri.EscapeDataString(searchQuery.Trim());
            Navigation.NavigateTo($"/search?q={q}");
        }
    }
}
