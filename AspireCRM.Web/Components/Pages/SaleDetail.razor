@page "/sales/{Id:long}"
@rendermode InteractiveServer
@inject CrmApiClient Api
@inject NavigationManager Nav

<PageTitle>Сделка @(sale?.Name ?? "")</PageTitle>

<h1>Сделка</h1>

@if (sale is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger">@error</div>
    }
    @if (!string.IsNullOrEmpty(success))
    {
        <div class="alert alert-success">@success</div>
    }

    <div class="card mb-3">
        <div class="card-header"><h5>Основная информация</h5></div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Название</label>
                    <input @bind="sale.Name" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Контрагент</label>
                    <select @bind="sale.ContractorId" class="form-select">
                        <option value="0">-- Выберите --</option>
                        @foreach (var c in contractors)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Статус</label>
                    <span class="badge @StatusBadgeClass(sale.SaleStatus) fs-6">@StatusDisplay(sale.SaleStatus)</span>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Приоритет</label>
                    <select @bind="sale.Priority" class="form-select">
                        <option value="@SalePriority.High">Высокий</option>
                        <option value="@SalePriority.Medium">Средний</option>
                        <option value="@SalePriority.Low">Низкий</option>
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Дата старта</label>
                    <input @bind="sale.StartDate" class="form-control" type="date" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Воронка</label>
                    <select @bind="sale.SaleFunnelId" class="form-select">
                        <option value="">-- Выберите --</option>
                        @foreach (var f in funnels)
                        {
                            <option value="@f.Id">@f.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Этап</label>
                    <select @bind="sale.SaleStageId" class="form-select">
                        <option value="">-- Выберите --</option>
                        @foreach (var s in stages)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Тип сделки</label>
                    <select @bind="sale.SaleTypeId" class="form-select">
                        <option value="0">-- Выберите --</option>
                        @foreach (var t in types)
                        {
                            <option value="@t.Id">@t.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Валюта</label>
                    <select @bind="sale.CurrencyId" class="form-select">
                        <option value="">-- Выберите --</option>
                        @foreach (var c in currencies)
                        {
                            <option value="@c.Id">@c.Name (@c.Code)</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Маркетинговый эффект</label>
                    <input @bind="sale.MarketingEffect" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Объем продаж</label>
                    <input @bind="sale.SalesVolume" class="form-control" type="number" step="0.01" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Описание</label>
                <textarea @bind="sale.Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <button class="btn btn-primary me-2" @onclick="Save" disabled="@isLoading">Сохранить</button>
                <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/sales")'>Назад</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public long Id { get; set; }

    private Sale? sale;
    private bool isLoading;
    private string? error;
    private string? success;

    private List<Contractor> contractors = [];
    private List<SaleFunnel> funnels = [];
    private List<SaleStage> stages = [];
    private List<SaleType> types = [];
    private List<Currency> currencies = [];

    private string StatusDisplay(SaleStatus status) => status switch
    {
        SaleStatus.Active => "Активна",
        SaleStatus.Postponed => "Отложена",
        SaleStatus.PositiveClosed => "Закрыта успешно",
        SaleStatus.NegativeClosed => "Закрыта неуспешно",
        _ => status.ToString()
    };

    private string StatusBadgeClass(SaleStatus status) => status switch
    {
        SaleStatus.Active => "bg-success",
        SaleStatus.Postponed => "bg-warning text-dark",
        SaleStatus.PositiveClosed => "bg-primary",
        SaleStatus.NegativeClosed => "bg-danger",
        _ => "bg-light"
    };

    protected override async Task OnInitializedAsync()
    {
        var loadTask = LoadSale();
        var lookupTask = LoadLookups();
        await Task.WhenAll(loadTask, lookupTask);
    }

    private async Task LoadSale()
    {
        try
        {
            sale = await Api.GetSaleAsync(Id);
        }
        catch (Exception ex)
        {
            error = $"Ошибка загрузки: {ex.Message}";
        }
    }

    private async Task LoadLookups()
    {
        var tasks = new Task[]
        {
            Task.Run(async () => { try { contractors = await Api.GetContractorsListAsync(); } catch { } }),
            Task.Run(async () => { try { funnels = await Api.GetLookupAsync<SaleFunnel>("sale-funnels"); } catch { } }),
            Task.Run(async () => { try { stages = await Api.GetLookupAsync<SaleStage>("sale-stages"); } catch { } }),
            Task.Run(async () => { try { types = await Api.GetLookupAsync<SaleType>("sale-types"); } catch { } }),
            Task.Run(async () => { try { currencies = await Api.GetLookupAsync<Currency>("currencies"); } catch { } })
        };
        await Task.WhenAll(tasks);
    }

    private async Task Save()
    {
        if (sale is null) return;

        if (string.IsNullOrWhiteSpace(sale.Name))
        {
            error = "Название обязательно";
            return;
        }
        if (sale.ContractorId <= 0)
        {
            error = "Выберите контрагента";
            return;
        }
        if (sale.SaleTypeId <= 0)
        {
            error = "Выберите тип сделки";
            return;
        }

        isLoading = true;
        error = null;
        success = null;
        try
        {
            await Api.UpdateSaleAsync(Id, sale);
            success = "Сделка сохранена";
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}