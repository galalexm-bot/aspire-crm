@page "/leads"
@using AspireCRM.Web.Models
@rendermode InteractiveServer
@inject CrmApiClient Api
@inject NavigationManager Nav

<PageTitle>Лиды</PageTitle>

<h1>Лиды</h1>

<p>
    <a href="/leads/new" class="btn btn-primary">+ Новый лид</a>
    @if (selectedIds.Count > 0)
    {
        <button class="btn btn-info ms-2" @onclick="ActivateSelected" disabled="@isLoading">
            Активировать (@selectedIds.Count)
        </button>
        <button class="btn btn-secondary ms-2" @onclick="OpenAssignModal">
            Назначить ответственного (@selectedIds.Count)
        </button>
        <button class="btn btn-secondary ms-2" @onclick="OpenChangeSourceModal">
            Изменить источник (@selectedIds.Count)
        </button>
        <button class="btn btn-outline-secondary ms-2" @onclick="ClearSelection">Снять выделение</button>
    }
</p>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}
@if (!string.IsNullOrEmpty(success))
{
    <div class="alert alert-success">@success</div>
}

@if (leads is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>
                    <input type="checkbox" @bind="selectAll" @bind:after="ToggleSelectAll" />
                </th>
                <th>ID</th>
                <th>Название</th>
                <th>Статус</th>
                <th>Дата создания</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var lead in leads)
            {
                <tr>
                    <td>
                        <input type="checkbox" checked="@selectedIds.Contains(lead.Id)"
                               @onchange="() => ToggleSelection(lead.Id)" />
                    </td>
                    <td>@lead.Id</td>
                    <td>
                        @lead.Name
                        @if (lead.Status == LeadStatus.Dublicate)
                        {
                            <span class="badge bg-secondary ms-1">дубль</span>
                        }
                    </td>
                    <td>
                        <span class="badge @StatusBadgeClass(lead.Status)">@StatusDisplay(lead.Status)</span>
                    </td>
                    <td>@lead.CreatedAt.ToShortDateString()</td>
                    <td>
                        <a href="/leads/@lead.Id" class="btn btn-sm btn-outline-primary">Открыть</a>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(lead.Id)">Удалить</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (showAssignModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Назначить ответственного</h5>
                    <button type="button" class="btn-close" @onclick="CloseAssignModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Ответственный</label>
                        <select class="form-select" @bind="assignResponsibleId">
                            <option value="0">-- Не назначен --</option>
                            @foreach (var user in users)
                            {
                                <option value="@user.Id">@user.FirstName @user.LastName (@user.Email)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseAssignModal">Отмена</button>
                    <button type="button" class="btn btn-primary" @onclick="AssignSelected" disabled="@(assignResponsibleId == 0 || isLoading)">
                        @(isLoading ? "Сохранение..." : "Назначить")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (showChangeSourceModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Изменить источник</h5>
                    <button type="button" class="btn-close" @onclick="CloseChangeSourceModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Источник</label>
                        <select class="form-select" @bind="changeSourceId">
                            <option value="0">-- Не указан --</option>
                            @foreach (var source in leadSources)
                            {
                                <option value="@source.Id">@source.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseChangeSourceModal">Отмена</button>
                    <button type="button" class="btn btn-primary" @onclick="ChangeSourceSelected" disabled="@isLoading">
                        @(isLoading ? "Сохранение..." : "Изменить")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Lead>? leads;
    private HashSet<long> selectedIds = [];
    private bool selectAll;
    private bool isLoading;
    private string? error;
    private string? success;

    private List<UserDto> users = [];
    private List<LeadSource> leadSources = [];

    private bool showAssignModal;
    private long assignResponsibleId;

    private bool showChangeSourceModal;
    private long changeSourceId;

    protected override async Task OnInitializedAsync()
    {
        leads = await Api.GetLeadsAsync();
        users = await Api.GetUsersAsync();
        leadSources = await Api.GetLeadSourcesAsync();
    }

    private async Task Delete(long id)
    {
        await Api.DeleteLeadAsync(id);
        leads = await Api.GetLeadsAsync();
        selectedIds.Remove(id);
    }

    private void ToggleSelection(long id)
    {
        if (!selectedIds.Remove(id))
            selectedIds.Add(id);
        selectAll = selectedIds.Count == leads?.Count;
    }

    private void ToggleSelectAll()
    {
        if (leads is null) return;
        if (selectAll)
        {
            selectedIds = [.. leads.Select(l => l.Id)];
        }
        else
        {
            selectedIds.Clear();
        }
    }

    private void ClearSelection()
    {
        selectedIds.Clear();
        selectAll = false;
    }

    private async Task ActivateSelected()
    {
        isLoading = true;
        error = null;
        success = null;
        try
        {
            await Api.ActivateLeadsAsync([.. selectedIds]);
            success = $"Активировано лидов: {selectedIds.Count}";
            ClearSelection();
            leads = await Api.GetLeadsAsync();
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenAssignModal()
    {
        assignResponsibleId = 0;
        showAssignModal = true;
    }

    private void CloseAssignModal()
    {
        showAssignModal = false;
    }

    private async Task AssignSelected()
    {
        if (assignResponsibleId == 0) return;
        isLoading = true;
        error = null;
        success = null;
        try
        {
            await Api.BatchAssignAsync([.. selectedIds], assignResponsibleId);
            success = $"Назначено лидов: {selectedIds.Count}";
            ClearSelection();
            CloseAssignModal();
            leads = await Api.GetLeadsAsync();
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenChangeSourceModal()
    {
        changeSourceId = 0;
        showChangeSourceModal = true;
    }

    private void CloseChangeSourceModal()
    {
        showChangeSourceModal = false;
    }

    private async Task ChangeSourceSelected()
    {
        isLoading = true;
        error = null;
        success = null;
        try
        {
            await Api.BatchChangeSourceAsync([.. selectedIds], changeSourceId == 0 ? null : changeSourceId);
            success = $"Изменён источник для лидов: {selectedIds.Count}";
            ClearSelection();
            CloseChangeSourceModal();
            leads = await Api.GetLeadsAsync();
        }
        catch (Exception ex)
        {
            error = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string StatusDisplay(LeadStatus status) => status switch
    {
        LeadStatus.New => "Новый",
        LeadStatus.InHand => "В работе",
        LeadStatus.Qualified => "Квалифицирован",
        LeadStatus.Unqualified => "Неквалифицирован",
        LeadStatus.Dublicate => "Дубликат",
        LeadStatus.ConversationNotStart => "Разговор не состоялся",
        _ => status.ToString()
    };

    private string StatusBadgeClass(LeadStatus status) => status switch
    {
        LeadStatus.New => "bg-primary",
        LeadStatus.InHand => "bg-warning text-dark",
        LeadStatus.Qualified => "bg-success",
        LeadStatus.Unqualified => "bg-danger",
        LeadStatus.Dublicate => "bg-secondary",
        LeadStatus.ConversationNotStart => "bg-dark",
        _ => "bg-light"
    };
}