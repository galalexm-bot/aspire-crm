@using AspireCRM.Web.Models
@inject CrmApiClient Api

<div class="card mb-4">
    <div class="card-header">
        <h5 class="card-title mb-0">Сводка по лидам</h5>
    </div>
    <div class="card-body">
        @if (summary is null)
        {
            <p><em>Загрузка...</em></p>
        }
        else
        {
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="border rounded p-3 text-center bg-light">
                        <div class="fs-3 fw-bold text-primary">@summary.TotalNew</div>
                        <div class="text-muted">Новые</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="border rounded p-3 text-center bg-light">
                        <div class="fs-3 fw-bold text-warning">@summary.TotalInHand</div>
                        <div class="text-muted">В работе</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="border rounded p-3 text-center bg-light">
                        <div class="fs-3 fw-bold text-success">@summary.TotalQualified</div>
                        <div class="text-muted">Квалифицированы</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="border rounded p-3 text-center bg-light">
                        <div class="fs-3 fw-bold text-danger">@summary.TotalUnqualified</div>
                        <div class="text-muted">Неквалифицированы</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="border rounded p-3 text-center bg-light">
                        <div class="fs-3 fw-bold text-secondary">@summary.TotalDuplicate</div>
                        <div class="text-muted">Дубли</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="border rounded p-3 text-center bg-light">
                        <div class="fs-3 fw-bold text-info">@summary.TotalConversationNotStart</div>
                        <div class="text-muted">Разговор не состоялся</div>
                    </div>
                </div>
            </div>
            <hr />
            <div class="row">
                <div class="col">
                    <div class="text-muted">Всего лидов: <strong>@summary.TotalLeads</strong></div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private LeadSummary? summary;

    protected override async Task OnInitializedAsync()
    {
        summary = await Api.GetLeadSummaryAsync();
    }
}